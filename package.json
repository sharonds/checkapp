{
  "name": "article-checker",
  "version": "1.0.0",
  "description": "Plagiarism checker for AI-generated articles. Terminal UI powered by Ink + Copyscape.",
  "bin": {
    "article-checker": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun src/index.tsx",
    "setup": "bun src/index.tsx --setup",
    "build": "bash build.sh",
    "dev": "bun --watch src/index.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "exa-js": "^2.11.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "bun-types": "latest"
  }
}
